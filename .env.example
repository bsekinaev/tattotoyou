# ============================================
# APPLICATION
# ============================================
APP_NAME=Tattoo Assistant
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO
# Не наследовать системные HTTP_PROXY/HTTPS_PROXY/ALL_PROXY по умолчанию.
HTTP_TRUST_ENV=false

# ============================================
# TELEGRAM (получи у @BotFather)
# ============================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_CHAT_ID=

# ============================================
# VK (получи в VK Developers)
# ============================================
VK_ACCESS_TOKEN=
VK_GROUP_ID=
VK_API_VERSION=5.199
VK_WEBHOOK_SECRET=

# ============================================
# INSTAGRAM (Meta for Developers)
# ============================================
IG_ACCESS_TOKEN=
IG_APP_SECRET=
IG_PAGE_ID=

# ============================================
# GIGACHAT (Сбер)
# ============================================
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-Pro
# Необязательный PEM-файл корневого сертификата НУЦ Минцифры.
# Оставьте пустым, если сертификат установлен в системное хранилище доверия.
GIGACHAT_CA_BUNDLE=

# ============================================
# DATABASE (PostgreSQL)
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=tattoo_assistant
POSTGRES_USER=tattoo_user
POSTGRES_PASSWORD=replace_with_a_long_random_password

# ============================================
# REDIS
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0
REDIS_PASSWORD=replace_with_a_long_random_password

# ============================================
# LOCAL DOCKER PORTS (docker-compose.dev.yml)
# ============================================
API_EXPOSED_PORT=8000
POSTGRES_EXPOSED_PORT=5433
REDIS_EXPOSED_PORT=6380

# ============================================
# SECURITY
# ============================================
SECRET_KEY=change-this-to-random-string-at-least-32-chars
ADMIN_API_KEY=replace_with_a_random_admin_key_at_least_32_chars
ENCRYPTION_KEY=

# ============================================
# OBSERVABILITY
# ============================================
SENTRY_DSN=