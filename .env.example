# ============================================
# APPLICATION
# ============================================
APP_NAME=Tattoo Assistant
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# ============================================
# TELEGRAM (получи у @BotFather)
# ============================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_CHAT_ID=

# ============================================
# VK (получи в VK Developers)
# ============================================
VK_ACCESS_TOKEN=
VK_GROUP_ID=
VK_API_VERSION=5.199
VK_WEBHOOK_SECRET=

# ============================================
# INSTAGRAM (Meta for Developers)
# ============================================
IG_ACCESS_TOKEN=
IG_APP_SECRET=
IG_PAGE_ID=

# ============================================
# GIGACHAT (Сбер)
# ============================================
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_SCOPE=
GIGACHAT_MODEL=GigaChat-Pro

# ============================================
# DATABASE (PostgreSQL)
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tattoo_assistant
POSTGRES_USER=tattoo_user
POSTGRES_PASSWORD=change_me_in_production

# ============================================
# REDIS
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================
# SECURITY
# ============================================
SECRET_KEY=change-this-to-random-string-at-least-32-chars
ENCRYPTION_KEY=

# ============================================
# OBSERVABILITY
# ============================================
SENTRY_DSN=